### Variables
# @no-log
@host = https://convenient-nonie-neberg-ad5744ad.koyeb.app
# @host = https://n8n.neberg.de

### Create identity — Teamleiter Finanzen
POST {{host}}/webhook/helga-create-identity
Content-Type: application/json

{
  "action": "route_message",
  "target_agent": "@Helga",
  "intent": "hr_request",
  "payload": {
    "message": "Create Teamleiter Finanzen",
    "context": "",
    "module_scope": "Module.Finanzen",
    "role": "teamleiter"
  }
}

